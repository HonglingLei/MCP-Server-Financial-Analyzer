# Transport: 'stdio' for local Claude Desktop, 'streamable-http' for cloud/remote
TRANSPORT=stdio

# HTTP server settings (only used when TRANSPORT=streamable-http)
HOST=0.0.0.0
PORT=8000

# SEC EDGAR identity - required by EDGAR's fair-use policy
# Format: "Your Name your@email.com"
EDGAR_IDENTITY=Your Name your@email.com

# Optional: Bearer token to protect the HTTP endpoint (set to any random string)
# MCP_AUTH_TOKEN=your-secret-token-here
